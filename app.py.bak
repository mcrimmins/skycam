import os
import time
import threading
import subprocess
from flask import Flask, render_template, request, redirect, url_for

app = Flask(__name__)

# Core Folder Paths
BASE_DIR = os.path.dirname(os.path.abspath(__file__))
IMG_DIR = os.path.join(BASE_DIR, 'static', 'images')
os.makedirs(IMG_DIR, exist_ok=True)

# Shared Runtime App State
app.config['INTERVAL'] = 30  # Default loop delay in seconds
app.config['AUTO_ON'] = True

def capture_frame():
    """Triggers hardware capture and uses Pillow to draw LARGE metadata text"""
    timestamp = time.strftime("%Y%m%d_%H%M%S")
    filename = f"frame_{timestamp}.jpg"
    filepath = os.path.join(IMG_DIR, filename)
    latest_path = os.path.join(IMG_DIR, 'latest.jpg')
    
    # 1. Read the Pi's live internal thermal sensor
    try:
        with open("/sys/class/thermal/thermal_zone0/temp", "r") as f:
            temp_c = int(f.read()) / 1000.0
            temp_f = (temp_c * 9/5) + 32
            temp_string = f"CPU: {temp_c:.1f}°C / {temp_f:.1f}°F"
    except Exception:
        temp_string = "CPU: Unknown"

    # 2. Capture a clean, un-annotated image from the hardware
    cmd = f"rpicam-jpeg -o {filepath} --width 1920 --height 1080 --nopreview"
    subprocess.run(cmd, shell=True)
    
    # 3. Use Pillow to draw the custom status bar if the image saved successfully
    if os.path.exists(filepath):
        from PIL import Image, ImageDraw, ImageFont
        
        try:
            # Open the captured image
            img = Image.open(filepath)
            draw = ImageDraw.Draw(img)
            
            # Format text string
            display_time = time.strftime("%Y-%m-%d %I:%M:%S %p")
            overlay_text = f"Tucson SkyCam  |  {display_time}  |  {temp_string}"
            
            # Load the system TrueType font and set a larger size (e.g., 32pt or 36pt)
            font_path = "/usr/share/fonts/truetype/dejavu/DejaVuSans-Bold.ttf"
            
            if os.path.exists(font_path):
                # Scale up to size 32 for massive, easy-to-read text on a TV or phone
                font = ImageFont.truetype(font_path, 32)
                banner_height = 65
                text_y_position = 10
            else:
                # Fallback if font isn't found
                font = ImageFont.load_default()
                banner_height = 45
                text_y_position = 12
            
            # Draw a thicker dark banner to accommodate the larger font (1920 x banner_height)
            draw.rectangle([0, 0, 1920, banner_height], fill=(0, 0, 0, 160))
            
            # Draw the text with the custom font
            draw.text((25, text_y_position), overlay_text, fill=(255, 255, 255), font=font)
            
            # Save the stamped image back over itself
            img.save(filepath, quality=90)
            
	    # Mirror copy to the live view pointer ONLY after saving completes safely
            subprocess.run(f"cp {filepath} {latest_path}", shell=True)

        except Exception as e:
            print(f"Pillow drawing error: {e}")
            
def auto_capture_thread():
    """Background loop that steps autonomously through intervals"""
    while True:
        if app.config['AUTO_ON']:
            try:
                capture_frame()
            except Exception as e:
                print(f"Loop Capture Error: {e}")
        
        # Continuously monitor interval variables actively
        time.sleep(app.config['INTERVAL'])

# Start the background execution sequence immediately on launch
threading.Thread(target=auto_capture_thread, daemon=True).start()

@app.route('/')
def index():
    # 1. Scan directory for captured frames
    all_files = os.listdir(IMG_DIR)
    raw_images = sorted([f for f in all_files if f.startswith('frame_') and f.endswith('.jpg')], reverse=True)
    
    # Nested Dictionary Structure: { "YYYY-MM-DD": { "HH:00 AM/PM": [img1, img2...] } }
    grouped_images = {}
    
    for img in raw_images:
        try:
            # Filename format: frame_YYYYMMDD_HHMMSS.jpg
            parts = img.split('_')
            date_part = parts[1]
            time_part = parts[2]
            
            # Format Date: YYYY-MM-DD
            formatted_date = f"{date_part[:4]}-{date_part[4:6]}-{date_part[6:8]}"
            
            # Format Hour: Convert 24h 'HH' into friendly 12h 'HH:00 AM/PM'
            raw_hour = int(time_part[:2])
            if raw_hour == 0:
                formatted_hour = "12:00 AM"
            elif raw_hour == 12:
                formatted_hour = "12:00 PM"
            elif raw_hour > 12:
                formatted_hour = f"{raw_hour - 12:02d}:00 PM"
            else:
                formatted_hour = f"{raw_hour:02d}:00 AM"
                
        except Exception:
            formatted_date = "Unknown Date"
            formatted_hour = "Unknown Hour"
            
        # Build out the nested dictionary safely
        if formatted_date not in grouped_images:
            grouped_images[formatted_date] = {}
        if formatted_hour not in grouped_images[formatted_date]:
            grouped_images[formatted_date][formatted_hour] = []
            
        grouped_images[formatted_date][formatted_hour].append(img)
        
    timelapse_exists = os.path.exists(os.path.join(IMG_DIR, 'timelapse.mp4'))
    
    return render_template('index.html', 
                           grouped_images=grouped_images, 
                           config=app.config, 
                           timelapse_exists=timelapse_exists,
                           cache_buster=time.time())

@app.route('/snap')
def snap():
    capture_frame()
    return redirect(url_for('index'))

@app.route('/update_settings', methods=['POST'])
def update_settings():
    action = request.form.get('action')
    try:
        app.config['INTERVAL'] = int(request.form.get('interval', 30))
    except ValueError:
        app.config['INTERVAL'] = 30
        
    if action == 'start':
        app.config['AUTO_ON'] = True
    elif action == 'stop':
        app.config['AUTO_ON'] = False
        
    return redirect(url_for('index'))

@app.route('/compile_selected', methods=['POST'])
def compile_selected():
    selected = request.form.getlist('selected_images')
    if not selected:
        return "No images selected!", 400
        
    # Sort chronological order (reversing the dashboard UI display presentation)
    selected.sort()
    
    # Create the text manifest mapping instruction blocks for FFmpeg
    manifest_path = os.path.join(BASE_DIR, 'sequence.txt')
    output_video = os.path.join(IMG_DIR, 'timelapse.mp4')
    
    with open(manifest_path, 'w') as f:
        for img in selected:
            img_path = os.path.join(IMG_DIR, img)
            f.write(f"file '{img_path}'\n")
            f.write("duration 0.1\n")  # Sets display rate at 10 frames per second
            
    # Clean up any lingering target references
    subprocess.run(f"rm -f {output_video}", shell=True)
    
    # Safe decoupled compilation thread call to protect low resource host
    ffmpeg_cmd = f"ffmpeg -f concat -safe 0 -i {manifest_path} -c:v libx264 -pix_fmt yuv420p {output_video}"
    subprocess.Popen(ffmpeg_cmd, shell=True)
    
    return "<h2>Stitching selected frames together in background...</h2><br><a href='/'>Return to Dashboard</a>"

if __name__ == '__main__':
    app.run(host='0.0.0.0', port=8000)

@app.route('/delete_selected', methods=['POST'])
def delete_selected():
    selected = request.form.getlist('selected_images')
    if not selected:
        return "No images selected!", 400
        
    for img in selected:
        # Secure the path to ensure files are only deleted out of the images directory
        if img.startswith('frame_') and img.endswith('.jpg'):
            img_path = os.path.join(IMG_DIR, img)
            if os.path.exists(img_path):
                try:
                    os.remove(img_path)
                except Exception as e:
                    print(f"Error deleting {img}: {e}")
                    
    # If the current latest.jpg was deleted, clean it up or let the next snap overwrite it
    return redirect(url_for('index'))
